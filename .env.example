# Single .env for both Vite and the FastAPI backend.
# Vite reads only `VITE_*` keys; backend reads the rest. They cohabit.

# ── Secrets ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── Backend: database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/litmatch

# ── Backend: models ───────────────────────────────────────
CHAT_MODEL=gpt-5.4-nano
CHAT_REASONING_EFFORT=none
CHAT_RESPONSE_VERBOSITY=low
CHAT_GUARDRAIL_MODEL=gpt-5.4-nano
CHAT_GUARDRAIL_LLM_ENABLED=true
CHAT_GUARDRAIL_TIMEOUT_SECONDS=4.0
CODEX_MODEL=codex-mini
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# ── Backend: RAG tuning ───────────────────────────────────
KNOWLEDGE_BASE_DIR=./knowledge_base
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.0

# ── Backend: scoring (mirrors PRD §6.5; FE has matching constants) ──
POINTS_MATCH=10
POINTS_CHALLENGE_COMPLETE=50
POINTS_CHALLENGE_PASS_BONUS=40
CHALLENGE_PASS_THRESHOLD=4

# ── Backend: app ──────────────────────────────────────────
DEBUG=false

# ── Backend: auth / OAuth ─────────────────────────────────
SESSION_SECRET_KEY=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=litmatch_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=1209600
OAUTH_POST_LOGIN_REDIRECT=http://localhost:5173
OAUTH_ALLOWED_REDIRECT_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","capacitor://localhost","https://localhost"]
OAUTH_CALLBACK_BASE_URL=http://localhost:8081
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_GOOGLE_SERVER_METADATA_URL=https://accounts.google.com/.well-known/openid-configuration
OAUTH_GOOGLE_SCOPE=openid email profile

# ── Frontend (Vite) ───────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8081
# Endpoints that hit the real backend; anything not listed stays mock.
# Recognised: auth, deck, characters, match, challenge, leaderboard, chat
VITE_REAL_ENDPOINTS=auth,leaderboard,characters,deck,match,challenge,chat
